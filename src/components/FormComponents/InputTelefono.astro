---
const { label, type, id, name, placeholder } = Astro.props;
---

<div class="flex flex-col space-y-1">
  <label for={id} class="text-sm prose font-semibold">{label}</label>
  <div class="flex flex-row items-center">
    <span class="border-r-0 px-4 py-3 outline-1 outline-[#D0D5DD] rounded-lg"
      >EC</span
    >
    <input
      class="border-l-0 px-4 py-3 outline-1 outline-[#D0D5DD] rounded-lg w-full"
      type={type}
      id={id}
      name={name}
      placeholder={placeholder}
    />
  </div>
</div>
