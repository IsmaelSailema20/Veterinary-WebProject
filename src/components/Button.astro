---
const { href, text, id } = Astro.props;
---

<div class="inline-flex">
  <a
    id={id}
    href={href}
    target="_blank"
    class="whitespace-nowrap w-full hover:cursor-pointer px-6 py-3 font-bold text-base rounded-[14px] text-white bg-[#47D15D] hover:bg-[#36A446] hover:text-white transition duration-300 ease-in-out"
  >
    {text}
  </a>
</div>
