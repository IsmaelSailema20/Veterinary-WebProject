---
import SectionContainer from "../components/SectionContainer.astro";
import Carousel from "../components/Carousel.tsx";
---

<SectionContainer
  class="lg:w-[1120px] h-fit m-auto py-26 px-4 w-full"
  id="nuestro_equipo"
>
  <div class="text-center w-full">
    <h1 class="lg:text-4xl text-3xl text-[#3EBB52] font-bold mb-4">
      Conoce a nuestro equipo
    </h1>
    <span class="prose font-semibold md:text-base text-sm">
      Profesionales apasionados por el bienestar de tu mascota. En nuestra
      clínica, contamos con un equipo de expertos dedicados a brindar el mejor
      cuidado y atención a tus compañeros peludos 🐾
    </span>
  </div>

  <!-- Componente del Carrusel -->
  <Carousel client:load />
</SectionContainer>
