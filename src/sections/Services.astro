---
import CardServices from "../components/CardServices.astro";
import SectionContainer from "../components/SectionContainer.astro";
import { servicesData } from "../data/ServicesData";
---

<SectionContainer
  class="lg:w-[1120px] h-fit m-auto py-26 px-4 w-full"
  id="servicios"
>
  <div class="text-center w-full">
    <h1 class="lg:text-4xl md:text-3xl text-2xl text-[#3EBB52] font-bold mb-4">
      Conoce Nuestros Sevicios
    </h1>
    <span class="prose font-semibold md:text-base text-sm"
      >Servicios que cuidan de ellos como tú lo harías 😽</span
    >
  </div>
  <div
    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 gap-12 sm:gap-8 lg:gap-[91px] p-4 sm:p-8 lg:p-16"
  >
    {
      servicesData.map((service) => (
        <CardServices
          srcMainImage={service.srcMainImage}
          alt={service.alt}
          title={service.title}
          srcIconTitle={service.srcIconTitle}
          description={service.description}
          altIconTitle={service.altIconTitle}
          estimatedTime={service.estimatedTime}
        />
      ))
    }
  </div>
</SectionContainer>
